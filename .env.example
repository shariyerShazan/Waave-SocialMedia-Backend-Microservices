# ==============================================================================
# WAAVE MICROSERVICE PLATFORM - APPLICATION ENVIRONMENTS TEMPLATE
# ==============================================================================

# Global Broker Configuration
KAFKA_BROKERS=localhost:9092

# HTTP / Media URLs
MEDIA_HTTP_BASE_URL=http://localhost:4009

# ------------------------------------------------------------------------------
# 1. API GATEWAY Configs
# ------------------------------------------------------------------------------
API_GATEWAY_HTTP_PORT=4000
API_GATEWAY_REDIS_HOST=localhost
API_GATEWAY_REDIS_PORT=6379

JWT_ACCESS_SECRET=super_secret_access_key_12345!
JWT_REFRESH_SECRET=super_secret_refresh_key_12345!

# Downstream gRPC Routes
AUTH_SERVICE_GRPC_URL=localhost:3001
USER_SERVICE_GRPC_URL=localhost:3002
MEDIA_SERVICE_GRPC_URL=localhost:3009
FEED_SERVICE_GRPC_URL=localhost:3004
POST_SERVICE_GRPC_URL=localhost:3011
CHAT_SERVICE_GRPC_URL=localhost:3005
NOTIFICATION_SERVICE_GRPC_URL=localhost:3007

# ------------------------------------------------------------------------------
# 2. AUTH SERVICE Configs
# ------------------------------------------------------------------------------
AUTH_GRPC_PORT=3001
AUTH_HTTP_PORT=4001
AUTH_REDIS_HOST=localhost
AUTH_REDIS_PORT=6379
AUTH_DB_PRIMARY_URL="postgresql://postgres:postgres@localhost:5432/auth_db?schema=public"
MAX_LOGIN_ATTEMPTS=5

# ------------------------------------------------------------------------------
# 3. USER SERVICE Configs
# ------------------------------------------------------------------------------
USER_GRPC_PORT=3002
USER_HTTP_PORT=4002
USER_REDIS_HOST=localhost
USER_REDIS_PORT=6379
USER_DB_PRIMARY_URL="postgresql://postgres:postgres@localhost:5432/user_db?schema=public"

# ------------------------------------------------------------------------------
# 4. MEDIA SERVICE Configs
# ------------------------------------------------------------------------------
MEDIA_GRPC_PORT=3009
MEDIA_HTTP_PORT=4009
MEDIA_REDIS_HOST=localhost
MEDIA_REDIS_PORT=6379
MEDIA_MONGO_DB_URL="mongodb://localhost:27017/media_service"

# ------------------------------------------------------------------------------
# 5. FEED SERVICE Configs
# ------------------------------------------------------------------------------
FEED_GRPC_PORT=3004
FEED_HTTP_PORT=4004
FEED_REDIS_HOST=localhost
FEED_REDIS_PORT=6379

# ------------------------------------------------------------------------------
# 6. POST SERVICE Configs
# ------------------------------------------------------------------------------
POST_GRPC_PORT=3011
POST_HTTP_PORT=4011
POST_REDIS_HOST=localhost
POST_REDIS_PORT=6379
POST_DB_URL="postgresql://postgres:postgres@localhost:5432/post_db?schema=public"

# ------------------------------------------------------------------------------
# 7. CHAT SERVICE Configs
# ------------------------------------------------------------------------------
CHAT_GRPC_PORT=3005
CHAT_HTTP_PORT=4005
CHAT_MONGO_DB_URL="mongodb://localhost:27017/chat_db"
CHAT_REDIS_HOST=localhost
CHAT_REDIS_PORT=6379

# ------------------------------------------------------------------------------
# 8. NOTIFICATION SERVICE Configs
# ------------------------------------------------------------------------------
NOTIFICATION_GRPC_PORT=3007
NOTIFICATION_HTTP_PORT=4010
NOTIFICATION_REDIS_HOST=localhost
NOTIFICATION_REDIS_PORT=6379
NOTIFICATION_MONGO_DB_URL="mongodb://localhost:27017/notification_db"